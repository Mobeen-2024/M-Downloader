{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mdownloader",
  "version": "0.1.0",
  "identifier": "com.mdownloader.mobile",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm.cmd run dev --prefix ui",
    "beforeBuildCommand": "npm.cmd run build --prefix ui"
  },
  "app": {
    "windows": [
      {
        "title": "Mdownloader",
        "width": 1200,
        "height": 760,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
